// ~/.config/zellij/layouts/dev.kdl
// Launch with:  zellij --layout dev
// Tab 1 "code": big editor pane on top, terminal strip on the bottom.
// Tab 2 "logs": single full-height shell for tailing logs / running servers.

layout {
    default_tab_template {
        // keep the status bars on every tab
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="code" focus=true {
        pane size="70%" name="editor"
        pane size="30%" name="terminal"
    }

    tab name="logs" {
        pane name="logs"
    }
}
